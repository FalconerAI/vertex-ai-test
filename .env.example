# GCP project ID (from `gcloud config get-value project` or instance metadata)
VERTEX_PROJECT=your-gcp-project-id

# GCP region for Vertex AI (must have Claude models enabled)
VERTEX_LOCATION=us-east5

# Optional: custom Vertex AI endpoint URL
# VERTEX_BASE_URL=https://custom-endpoint.example.com

# Path to GCP service account key file (optional if running on GCE with ambient credentials)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
